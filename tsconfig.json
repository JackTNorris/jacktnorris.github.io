{
  "compilerOptions": {
    "target": "es6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node", // TODO: fix deprecation
    "resolveJsonModule": true,
    "isolatedModules": true,
    "downlevelIteration": true, // TODO: fix deprecation
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "src", // TODO: fix deprecation
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src"
  ]
}
